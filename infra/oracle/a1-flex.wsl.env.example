# Copy this file to infra/oracle/a1-flex.wsl.env and fill in WSL/Linux paths.
# Run from WSL with: bash scripts/oci/try-a1-loop.sh

OCI_CONFIG_FILE=$HOME/.oci/config
OCI_PROFILE=DEFAULT
OCI_REGION=ap-chuncheon-1

OCI_COMPARTMENT_ID=ocid1.compartment.oc1..replace-me
OCI_AVAILABILITY_DOMAIN=replace-me:AP-CHUNCHEON-1-AD-1
OCI_SUBNET_ID=ocid1.subnet.oc1.ap-chuncheon-1.replace-me
OCI_IMAGE_ID=ocid1.image.oc1.ap-chuncheon-1.replace-me
OCI_SSH_PUBLIC_KEY_FILE=/mnt/c/Users/PC/Documents/New\ project\ 4/infra/oracle/a1-flex-ssh.pub

OCI_INSTANCE_DISPLAY_NAME=always-free-a1-flex
OCI_SHAPE=VM.Standard.A1.Flex
OCI_OCPUS=1
OCI_MEMORY_GB=6
OCI_BOOT_VOLUME_GB=50
OCI_A1_RETRY_INTERVAL_MIN_SECONDS=70
OCI_A1_RETRY_INTERVAL_MAX_SECONDS=100
OCI_A1_RATE_LIMIT_BACKOFF_SECONDS=300
