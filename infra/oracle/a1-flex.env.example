# Copy this file to infra/oracle/a1-flex.env and fill in your OCI values.
# The automation keeps existing E2 instances untouched and only tries to create A1.Flex.

OCI_CONFIG_FILE=C:\Users\PC\.oci\config
OCI_PROFILE=DEFAULT
OCI_REGION=ap-chuncheon-1

OCI_COMPARTMENT_ID=ocid1.compartment.oc1..replace-me
OCI_AVAILABILITY_DOMAIN=replace-me:AP-CHUNCHEON-1-AD-1
OCI_SUBNET_ID=ocid1.subnet.oc1.ap-chuncheon-1.replace-me
OCI_IMAGE_ID=ocid1.image.oc1.ap-chuncheon-1.replace-me
OCI_SSH_PUBLIC_KEY_FILE=C:\Users\PC\.ssh\id_rsa.pub

OCI_INSTANCE_DISPLAY_NAME=always-free-a1-flex
OCI_SHAPE=VM.Standard.A1.Flex
OCI_OCPUS=1
OCI_MEMORY_GB=6
OCI_BOOT_VOLUME_GB=50
